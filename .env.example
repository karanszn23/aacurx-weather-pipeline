# Copy this file to .env and fill in values for local development.
# All variables are optional — defaults are shown in config.py.

# Pipeline paths
DB_PATH=warehouse.duckdb
DATA_DIR=data

# API endpoints (Open-Meteo — free, no key required)
WEATHER_API=https://archive-api.open-meteo.com/v1/archive
GEOCODE_API=https://geocoding-api.open-meteo.com/v1/search

# Timezone for timestamp interpretation and weather fetching
PIPELINE_TIMEZONE=Europe/London

# Geocoding preferences
GEOCODE_COUNTRY_CODE=GB
CITY_GEOCODE_OVERRIDES_PATH=city_geocode_overrides.csv
GEOCODE_REQUEST_DELAY_SECONDS=0.2

# Weather fetch rate limiting
WEATHER_REQUEST_DELAY_SECONDS=1.0

# HTTP retry / timeout settings
HTTP_MAX_RETRIES=4
HTTP_BACKOFF_BASE_SECONDS=2.0
HTTP_BACKOFF_MAX_SECONDS=60.0
HTTP_TIMEOUT_SECONDS=30

# Data quality thresholds
WEATHER_COVERAGE_ALERT_THRESHOLD=95.0

# Poor weather classification thresholds
POOR_WEATHER_PRECIP_MM=5.0
POOR_WEATHER_WIND_KMH=50.0
